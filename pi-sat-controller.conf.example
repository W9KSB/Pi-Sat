[server]
host = 0.0.0.0
port = 80
# Enable browser caching for GUI static resources.
gui_resources_caching = false

[station]
name = Home
grid_locator = NN00AA
latitude_deg = 40.020833
longitude_deg = 80.041667
elevation_m = 250.0

[tle]
source_url = https://celestrak.org/NORAD/elements/gp.php?GROUP=amateur&FORMAT=tle
cache_dir = data/tle_cache
stale_after_hours = 48

[profiles]
satellites_file = data/satellites.json
[my_satellites]
min_pass_elevation_deg = 10.0
autotrack_next_pass = true
satellite_25544 = ISS
satellite_27607 = SO-50
satellite_44909 = RS-44

[rx]
enabled = false
# Assign a configured CAT device from the My CAT Devices inventory.
device_id = 
# Select which VFO Hamlib should control for RX: current, A, or B.
target_vfo = current
# Enable verbose CAT/Hamlib command logging for this role.
cat_debug_logging = false
# Enable frequency writes for this role.
write_enabled = false

[tx]
enabled = false
# Assign a configured CAT device from the My CAT Devices inventory.
device_id = 
# Select which VFO Hamlib should control for TX: current, A, or B.
target_vfo = current
# For one local radio serving both RX and TX, enable Hamlib split operation.
# This remains a config-file-only compatibility option.
shared_local_split_mode = false
# Enable verbose CAT/Hamlib command logging for this role.
cat_debug_logging = false
# Enable frequency writes for this role.
write_enabled = false

[rotator]
enabled = false
# Set below to local for USB/serial connected devices and network for rotctld/Hamlib devices.
connectivity = network
# If connectivity is set to network, these values below are used.
host = 127.0.0.1
port = 4534
# If connectivity is set to local, these values below are used.
serial_port = 
baud = 
model_id = 
# Enable verbose rotator/Hamlib command logging for this role.
cat_debug_logging = 
# Enable rotator position writes. Keep false until hardware is ready.
write_enabled = false
timeout_s = 2.0
min_elevation_deg = 0.0
home_azimuth_deg = 0.0
home_elevation_deg = 0.0
return_home_after_pass = false

[automation]
aos_script =
los_script =

[safety]
tx_inhibit_below_horizon = true
tx_inhibit_on_cat_loss = true
tx_inhibit_without_valid_pass = true
frequency_deadband_hz = 10
cat_rate_limit_hz = 4
tracking_update_interval_ms = 1000
device_offline_failure_threshold = 3
